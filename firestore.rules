rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Entity validation functions
    function isValidChurch(data) {
      return data.keys().hasAll(['id', 'name', 'passwordHash', 'mapName', 'logoName'])
        && data.id is string
        && data.name is string
        && data.passwordHash is string
        && data.mapName is string
        && data.logoName is string;
    }

    function isValidAppSettings(data) {
      return data.keys().hasAll(['id', 'mapName', 'churchName', 'themeColor', 'logoName'])
        && data.id is string
        && data.mapName is string
        && data.churchName is string
        && data.themeColor is string
        && data.logoName is string;
    }

    function isValidMember(data) {
      return data.keys().hasAll(['id', 'churchId', 'fullName', 'phoneNumber', 'gender', 'department', 'level', 'faculty', 'residence', 'birthday', 'dateJoined', 'status', 'mapName'])
        && data.id is string
        && data.churchId is string
        && data.fullName is string
        && data.phoneNumber is string
        && data.gender is string
        && data.department is string
        && data.level is string
        && data.faculty is string
        && data.residence is string
        && data.birthday is string
        && data.dateJoined is string
        && data.status is string
        && data.mapName is string;
    }

    function isValidVisitor(data) {
      return data.keys().hasAll(['id', 'churchId', 'fullName', 'phoneNumber', 'gender', 'invitedBy', 'dateVisited', 'status'])
        && data.id is string
        && data.churchId is string
        && data.fullName is string
        && data.phoneNumber is string
        && data.gender is string
        && data.invitedBy is string
        && data.dateVisited is string
        && data.status is string;
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['id', 'churchId', 'memberId', 'date', 'serviceType'])
        && data.id is string
        && data.churchId is string
        && data.memberId is string
        && data.date is string
        && data.serviceType is string;
    }

    function isValidPrayerRequest(data) {
      return data.keys().hasAll(['id', 'churchId', 'fullName', 'phoneNumber', 'request', 'dateSubmitted', 'status'])
        && data.id is string
        && data.churchId is string
        && data.fullName is string
        && data.phoneNumber is string
        && data.request is string
        && data.dateSubmitted is string
        && data.status is string;
    }

    function isValidFollowUp(data) {
      return data.keys().hasAll(['id', 'churchId', 'name', 'phoneNumber', 'reason', 'status'])
        && data.id is string
        && data.churchId is string
        && data.name is string
        && data.phoneNumber is string
        && data.reason is string
        && data.status is string;
    }

    function isValidRecentActivity(data) {
      return data.keys().hasAll(['id', 'churchId', 'type', 'description', 'timestamp'])
        && data.id is string
        && data.churchId is string
        && data.type is string
        && data.description is string
        && data.timestamp is string;
    }

    function isValidFellowshipConnection(data) {
      return data.keys().hasAll(['id', 'churchId', 'senderId', 'receiverId', 'status', 'dateRequested'])
        && data.id is string
        && data.churchId is string
        && data.senderId is string
        && data.receiverId is string
        && data.status is string
        && data.dateRequested is string;
    }

    function isValidFellowshipNote(data) {
      return data.keys().hasAll(['id', 'churchId', 'senderId', 'senderName', 'receiverId', 'message', 'dateSent'])
        && data.id is string
        && data.churchId is string
        && data.senderId is string
        && data.senderName is string
        && data.receiverId is string
        && data.message is string
        && data.dateSent is string;
    }

    // Rules for collections (Express backend uses admin privilege which bypasses these, 
    // but we enforce strict zero-trust rules for any direct client access)
    match /churches/{churchId} {
      allow read: if true;
      allow create, update: if isValidChurch(request.resource.data);
      allow delete: if false;
    }

    match /appSettings/{settingsId} {
      allow read: if true;
      allow create, update: if isValidAppSettings(request.resource.data);
      allow delete: if false;
    }

    match /members/{memberId} {
      allow read: if true;
      allow create: if isValidMember(request.resource.data);
      allow update: if isValidMember(request.resource.data);
      allow delete: if false;
    }

    match /visitors/{visitorId} {
      allow read: if true;
      allow create, update: if isValidVisitor(request.resource.data);
      allow delete: if false;
    }

    match /attendance/{attendanceId} {
      allow read: if true;
      allow create: if isValidAttendance(request.resource.data);
      allow delete: if true;
    }

    match /prayerRequests/{requestId} {
      allow read: if true;
      allow create, update: if isValidPrayerRequest(request.resource.data);
      allow delete: if false;
    }

    match /followUps/{followUpId} {
      allow read: if true;
      allow create, update: if isValidFollowUp(request.resource.data);
      allow delete: if false;
    }

    match /recentActivities/{activityId} {
      allow read: if true;
      allow create: if isValidRecentActivity(request.resource.data);
      allow delete: if false;
    }

    match /fellowshipConnections/{connectionId} {
      allow read: if true;
      allow create, update: if isValidFellowshipConnection(request.resource.data);
      allow delete: if true;
    }

    match /fellowshipNotes/{noteId} {
      allow read: if true;
      allow create: if isValidFellowshipNote(request.resource.data);
      allow delete: if false;
    }
  }
}
